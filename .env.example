# Copy this file to .env.local and fill in your values

# Base path — must match basePath in next.config.js (leave empty for local dev if not using basePath)
NEXT_PUBLIC_BASE_PATH=

# Flutter backend API base URL
NEXT_PUBLIC_API_BASE_URL=Enter your API url...';//Replace with your API Path (Get from Control panel)


# Server-side only (used by the /api/proxy route — never sent to browser)
API_BASE_URL=Enter your API url...'; //Replace with your API Path (Get from Control panel)


# Your deployed app URL
NEXT_PUBLIC_APP_URL=http://localhost:9000

# Secret for session signing (generate a strong random string for production)
NEXTAUTH_SECRET=your-secret-here

# Firebase — get these from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDv8lz2mfppOZhU4AH9F2pWx3Os6IcoACg
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=yourappname-9aca3.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yourappname-9aca3
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=yourappname-9aca3.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=946063364931
